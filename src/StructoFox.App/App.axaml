<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="StructoFox.App.App"
             RequestedThemeVariant="Default">
             <!-- "Default" ThemeVariant follows system theme variant. "Dark" or "Light" are other available options. -->

    <Application.Styles>
        <FluentTheme />

        <!-- Hover/pressed: paint with the theme accent and put the background colour on top as text,
             so it stays readable on light themes (the accents are chosen to contrast the background). -->
        <Style Selector="Button:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource AccentBgBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource ContentBgBrush}" />
        </Style>
        <Style Selector="Button:pressed /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource AccentBgBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource ContentBgBrush}" />
        </Style>

        <!-- Text fields: Fluent overrides the field background per visual state with its own (dark)
             theme brushes, so a focused/hovered box turned black. Force our InputBg brush onto the
             template's border element in every state, and keep the text on our themed colour. -->
        <Style Selector="TextBox /template/ Border#PART_BorderElement">
            <Setter Property="Background" Value="{DynamicResource InputBgBrush}" />
        </Style>
        <Style Selector="TextBox:pointerover /template/ Border#PART_BorderElement">
            <Setter Property="Background" Value="{DynamicResource InputBgBrush}" />
        </Style>
        <Style Selector="TextBox:focus-within /template/ Border#PART_BorderElement">
            <Setter Property="Background" Value="{DynamicResource InputBgBrush}" />
        </Style>
        <Style Selector="TextBox">
            <Setter Property="Foreground" Value="{DynamicResource SidebarTextBrush}" />
        </Style>
        <Style Selector="TextBox:pointerover">
            <Setter Property="Foreground" Value="{DynamicResource SidebarTextBrush}" />
        </Style>
        <Style Selector="TextBox:focus-within">
            <Setter Property="Foreground" Value="{DynamicResource SidebarTextBrush}" />
        </Style>
    </Application.Styles>
</Application>