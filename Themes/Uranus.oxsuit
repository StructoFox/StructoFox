    <!-- Sidebar Surface -->
    <color key="SidebarBg" value="#0E2430"/>
    <color key="SidebarText" value="#98DED8"/>
    <color key="SidebarDim" value="#4890A0"/>
    <color key="SidebarHigh" value="#28A0B0"/>
    <color key="SidebarBorder" value="#00000000"/>

    <!-- Control Surface -->
    <color key="ControlBg" value="#163240"/>
    <color key="ControlHover" value="#1E4050"/>
    <color key="ControlText" value="#4890A0"/>
    <color key="ControlDim" value="#4890A0"/>
    <color key="ControlHigh" value="#28A0B0"/>
    <color key="ControlBorder" value="#00000000"/>

    <!-- Input Surface -->
    <color key="InputBg" value="#163240"/>
    <color key="InputText" value="#98DED8"/>
    <color key="InputDim" value="#4890A0"/>
    <color key="InputHigh" value="#28A0B0"/>
    <color key="InputBorder" value="#00000000"/>

    <!-- Accent -->
    <color key="AccentBg" value="#28A0B0"/>
    <color key="AccentText" value="#0E2430"/>
    <color key="AccentHighlight" value="#28A0B0"/>
    <color key="PrimaryAccent" value="#50B8C0"/>
