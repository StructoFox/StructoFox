    <color key="TertiaryAccent" value="#90D8D2"/>

    <!-- Primary Slot -->
    <color key="PrimaryBg" value="#081820"/>
    <color key="PrimaryText" value="#98DED8"/>
    <color key="PrimaryDim" value="#4890A0"/>
    <color key="PrimaryHigh" value="#28A0B0"/>
