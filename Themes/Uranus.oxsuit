    <!-- Secondary Slot -->
    <color key="SecondaryBg" value="#081C1E"/>
    <color key="SecondaryText" value="#98DED8"/>
    <color key="SecondaryDim" value="#4890A0"/>
    <color key="SecondaryHigh" value="#28A0B0"/>
