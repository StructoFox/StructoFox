<?xml version="1.0" encoding="utf-8"?>
<oxsuit version="1.0" name="Uranus">

  <colors>

    <!-- Content Surface -->
    <color key="ContentBg" value="#081A22"/>
    <color key="ContentText" value="#98DED8"/>
    <color key="ContentDim" value="#4890A0"/>
    <color key="ContentHigh" value="#28A0B0"/>
