    <!-- Primary Slot -->
    <color key="PrimaryBg" value="#EAE4D8"/>
    <color key="PrimaryText" value="#08101E"/>
    <color key="PrimaryDim" value="#D4AA3A"/>
    <color key="PrimaryHigh" value="#5888D8"/>
