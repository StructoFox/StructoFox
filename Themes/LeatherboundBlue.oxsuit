    <!-- Sidebar Surface -->
    <color key="SidebarBg" value="#1A2840"/>
    <color key="SidebarText" value="#D4AA3A"/>
    <color key="SidebarDim" value="#D4AA3A"/>
    <color key="SidebarHigh" value="#5888D8"/>
    <color key="SidebarBorder" value="#00000000"/>

    <!-- Control Surface -->
    <color key="ControlBg" value="#283858"/>
    <color key="ControlHover" value="#304470"/>
    <color key="ControlText" value="#D4AA3A"/>
    <color key="ControlDim" value="#D4AA3A"/>
    <color key="ControlHigh" value="#5888D8"/>
    <color key="ControlBorder" value="#00000000"/>

    <!-- Input Surface -->
    <color key="InputBg" value="#F4E8CC"/>
    <color key="InputText" value="#08101E"/>
    <color key="InputDim" value="#D4AA3A"/>
    <color key="InputHigh" value="#5888D8"/>
    <color key="InputBorder" value="#00000000"/>

    <!-- Accent -->
    <color key="AccentBg" value="#5888D8"/>
    <color key="AccentText" value="#1A2840"/>
