<?xml version="1.0" encoding="utf-8"?>
<oxsuit version="1.0" name="Leatherbound Blue">

  <colors>

    <!-- Content Surface -->
    <color key="ContentBg" value="#F4E8CC"/>
    <color key="ContentText" value="#08101E"/>
    <color key="ContentDim" value="#D4AA3A"/>
    <color key="ContentHigh" value="#5888D8"/>
