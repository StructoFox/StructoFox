    <!-- Sidebar Surface -->
    <color key="SidebarBg" value="#04060C"/>
    <color key="SidebarText" value="#E8E0C0"/>
    <color key="SidebarDim" value="#806040"/>
    <color key="SidebarHigh" value="#FFD820"/>
    <color key="SidebarBorder" value="#00000000"/>

    <!-- Control Surface -->
    <color key="ControlBg" value="#0C0E16"/>
    <color key="ControlHover" value="#141620"/>
    <color key="ControlText" value="#806040"/>
    <color key="ControlDim" value="#806040"/>
    <color key="ControlHigh" value="#FFD820"/>
    <color key="ControlBorder" value="#00000000"/>

    <!-- Input Surface -->
    <color key="InputBg" value="#0C0E16"/>
    <color key="InputText" value="#E8E0C0"/>
    <color key="InputDim" value="#806040"/>
    <color key="InputHigh" value="#FFD820"/>
    <color key="InputBorder" value="#00000000"/>

    <!-- Accent -->
    <color key="AccentBg" value="#FFD820"/>
    <color key="AccentText" value="#04060C"/>
