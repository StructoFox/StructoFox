    <color key="PrimaryAccent" value="#F0C010"/>
    <color key="SecondaryAccent" value="#2858E0"/>
    <color key="TertiaryAccent" value="#E07018"/>

    <!-- Primary Slot -->
    <color key="PrimaryBg" value="#161000"/>
    <color key="PrimaryText" value="#E8E0C0"/>
    <color key="PrimaryDim" value="#806040"/>
    <color key="PrimaryHigh" value="#FFD820"/>
