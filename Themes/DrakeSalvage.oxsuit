    <color key="PrimaryAccent" value="#E86818"/>
    <color key="SecondaryAccent" value="#C05018"/>
    <color key="TertiaryAccent" value="#A87830"/>

    <!-- Primary Slot -->
    <color key="PrimaryBg" value="#1C1008"/>
    <color key="PrimaryText" value="#D8C8A0"/>
    <color key="PrimaryDim" value="#786850"/>
    <color key="PrimaryHigh" value="#F08030"/>
    <color key="PrimaryBorder" value="#00000000"/>

    <!-- Secondary Slot -->
    <color key="SecondaryBg" value="#180C04"/>
    <color key="SecondaryText" value="#D8C8A0"/>
    <color key="SecondaryDim" value="#786850"/>
    <color key="SecondaryHigh" value="#F08030"/>
    <color key="SecondaryBorder" value="#00000000"/>

    <!-- Tertiary Slot -->
    <color key="TertiaryBg" value="#1A1208"/>
    <color key="TertiaryText" value="#D8C8A0"/>
    <color key="TertiaryDim" value="#786850"/>
    <color key="TertiaryHigh" value="#F08030"/>
