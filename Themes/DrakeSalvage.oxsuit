    <color key="ContentText" value="#D8C8A0"/>
    <color key="ContentDim" value="#786850"/>
    <color key="ContentHigh" value="#F08030"/>
    <color key="ContentBorder" value="#00000000"/>

    <!-- Sidebar Surface -->
    <color key="SidebarBg" value="#080705"/>
    <color key="SidebarText" value="#D8C8A0"/>
    <color key="SidebarDim" value="#786850"/>
    <color key="SidebarHigh" value="#F08030"/>
    <color key="SidebarBorder" value="#00000000"/>

    <!-- Control Surface -->
    <color key="ControlBg" value="#181410"/>
    <color key="ControlHover" value="#2A2218"/>
    <color key="ControlText" value="#786850"/>
    <color key="ControlDim" value="#786850"/>
    <color key="ControlHigh" value="#F08030"/>
    <color key="ControlBorder" value="#00000000"/>

    <!-- Input Surface -->
    <color key="InputBg" value="#181410"/>
    <color key="InputText" value="#D8C8A0"/>
    <color key="InputDim" value="#786850"/>
    <color key="InputHigh" value="#F08030"/>
    <color key="InputBorder" value="#00000000"/>

    <!-- Accent -->
    <color key="AccentBg" value="#F08030"/>
    <color key="AccentText" value="#080705"/>
