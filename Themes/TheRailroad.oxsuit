    <color key="SecondaryText" value="#D0C0A4"/>
    <color key="SecondaryDim" value="#705040"/>
    <color key="SecondaryHigh" value="#E03428"/>
    <color key="SecondaryBorder" value="#00000000"/>

    <!-- Tertiary Slot -->
